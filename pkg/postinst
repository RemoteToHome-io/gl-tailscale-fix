#!/bin/sh
# gl-tailscale-fix: post-install script
# Copyright (c) 2026 RemoteToHome Consulting (https://remotetohome.io)
# https://github.com/RemoteToHome-io/gl-tailscale-fix

# Restore user config saved by prerm (handles --force-reinstall which
# runs full teardown because opkg doesn't set PKG_UPGRADE=1).
# Precedence: saved config > existing config > default template.
if [ -f /tmp/ts-fix-config.saved ]; then
    mv /tmp/ts-fix-config.saved /etc/config/ts-fix
elif [ ! -f /etc/config/ts-fix ]; then
    cp /etc/config/ts-fix.default /etc/config/ts-fix
fi

# Restore original GL wrapper if it was modified (e.g., users who manually
# added --advertise-exit-node before the plugin existed). The plugin handles
# exit node natively, so the manual modification must be reverted to prevent
# conflicts. This runs here (not just in the installer script) so it applies
# regardless of installation method (LuCI upload, manual opkg, or installer).
if [ -f '/rom/usr/bin/gl_tailscale' ] && ! cmp -s '/rom/usr/bin/gl_tailscale' '/usr/bin/gl_tailscale'; then
    cp '/rom/usr/bin/gl_tailscale' '/usr/bin/gl_tailscale' 2>/dev/null || true
fi

# Ensure tailscale CLI symlink exists (combined binary installs only have
# tailscaled; the symlink may be missing after sysupgrade or manual cleanup)
if [ -f /usr/sbin/tailscaled ] && [ ! -e /usr/sbin/tailscale ]; then
    ln -sf tailscaled /usr/sbin/tailscale
fi

# Migrate: clean stale sysupgrade.conf entries from pre-v1.0.18
# (v1.0.18+ uses keep.d for binary persistence instead of sysupgrade.conf)
if [ -f /etc/sysupgrade.conf ]; then
    sed -i '\|^/usr/sbin/tailscale$|d' /etc/sysupgrade.conf 2>/dev/null
    sed -i '\|^/usr/sbin/tailscaled$|d' /etc/sysupgrade.conf 2>/dev/null
fi

# Firmware compatibility gate — don't enable service on 4.9+ firmware
# (native Tailscale enhancements overlap with plugin features)
fw_ver=$(awk '{print $1}' /etc/glversion 2>/dev/null)
if [ -n "$fw_ver" ]; then
    _major=$(echo "$fw_ver" | cut -d. -f1)
    _minor=$(echo "$fw_ver" | cut -d. -f2)
    if [ "$_major" -gt 4 ] 2>/dev/null || \
       { [ "$_major" -eq 4 ] && [ "$_minor" -ge 9 ]; } 2>/dev/null; then
        logger -t ts-fix "Incompatible firmware ($fw_ver) — plugin installed but service not enabled"
        # Still restart nginx so incompatibility banner shows in admin panel
        if [ -x /etc/init.d/nginx ]; then
            pgrep nginx >/dev/null 2>&1 && kill -9 $(pgrep nginx) 2>/dev/null
            /etc/init.d/nginx start 2>/dev/null
        fi
        exit 0
    fi
fi

# Enable and start procd service (registers UCI reload trigger for tailscale config)
if [ -x /etc/init.d/ts-fix ]; then
    /etc/init.d/ts-fix enable 2>/dev/null
    /etc/init.d/ts-fix start 2>/dev/null
fi

# Restart nginx to pick up new/updated RPC module and injection config
# (reload does NOT reliably clear module cache on GL routers)
if [ -x /etc/init.d/nginx ]; then
    kill -9 $(pgrep nginx) 2>/dev/null
    /etc/init.d/nginx start 2>/dev/null
fi

# Re-apply settings (exit node advertisement, kill switch, guest routing).
# Needed after --force-reinstall since prerm tears down firewall rules and
# tailscale flags. Runs in background to not block opkg — ts-fix-reapply
# handles its own timing (waits for tailscale Running state, uses flock).
if [ -x /usr/bin/ts-fix-reapply ]; then
    /usr/bin/ts-fix-reapply >/dev/null 2>&1 &
fi

exit 0
